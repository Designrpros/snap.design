{
  "name": "snap-design-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@snap/web",
    "dev:desktop": "turbo run dev --filter=@snap/desktop",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@snap/web",
    "build:desktop": "turbo run build --filter=@snap/desktop",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "react-router-dom": "^7.15.0"
  }
}
